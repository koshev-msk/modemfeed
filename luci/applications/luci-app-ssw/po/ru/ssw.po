# ── Map title ─────────────────────────────────────────────────────────────────

msgid "SSW - SIM Card switch"
msgstr "SSW — переключение SIM-карт"

# ── Modem / SIM sections ──────────────────────────────────────────────────────

msgid "Modem"
msgstr "Модем"

msgid "State"
msgstr "Состояние"

msgid "Enable the modem upon router startup."
msgstr "Включить модем при загрузке роутера."

msgid "Enable"
msgstr "Включён"

msgid "Disable"
msgstr "Выключен"

msgid "SIM Slot"
msgstr "Слот SIM"

msgid "Default SIM Slot"
msgstr "Основной слот SIM"

msgid "Select the primary slot. The other becomes the backup."
msgstr "Выбрать, какой слот будет основным. Другой слот становится резервным."

msgid "SLOT 1"
msgstr "Слот 1"

msgid "SLOT 2"
msgstr "Слот 2"

# ── Failover section ──────────────────────────────────────────────────────────

msgid "Signal-based failover"
msgstr "Переключение по качеству сигнала"

msgid ""
"Monitors signal quality (RSRP/RSCP) and link state via mwan3.<br />"
"Switches to the reserve SIM when the average signal drops below the threshold<br />"
"or the interface loses connectivity. Operates independently of the scheduled switch."
msgstr ""
"Отслеживает качество сигнала (RSRP/RSCP) и состояние канала через mwan3.<br />"
"Переключается на резервную SIM, когда средний сигнал падает ниже порогового<br />"
"значения или интерфейс теряет связь. Работает независимо от переключения по расписанию."

msgid "Enable failover"
msgstr "Включить переключение по сигналу"

msgid "Enable automatic SIM switching based on signal quality and link state."
msgstr ""
"Включить автоматическое переключение SIM-карты на основе качества сигнала и "
"состояния канала."

msgid "APN — default SIM"
msgstr "APN — основная SIM"

msgid ""
"Access Point Name used when operating on the default SIM slot.<br />"
"Applied automatically when reverting from the reserve SIM."
msgstr ""
"Точка доступа (APN), используемая при работе с основным слотом SIM.<br />"
"Применяется автоматически при возврате с резервной SIM."

msgid "APN — reserve SIM"
msgstr "APN — резервная SIM"

msgid "Access Point Name used when switching to the reserve SIM slot."
msgstr "Точка доступа (APN), используемая при переключении на резервный слот SIM."

msgid "Auto-revert to default SIM"
msgstr "Автоматический возврат на основную SIM"

msgid ""
"Automatically switch back to the default SIM after a period of time.<br />"
"The revert timeout starts at <code>2 × (Interval × Probes)</code> seconds<br />"
"and doubles with each consecutive failed attempt."
msgstr ""
"Автоматически вернуться на основную SIM через некоторое время.<br />"
"Начальный таймаут возврата равен <code>2 × (Интервал × Попытки)</code> секунд<br />"
"и удваивается при каждой последующей неудачной попытке переключения."

msgid "Signal threshold (RSRP/RSCP)"
msgstr "Порог сигнала (RSRP/RSCP)"

msgid ""
"Switch to the reserve SIM when the averaged signal falls below this value.<br />"
"For LTE and 5G use <strong>RSRP</strong>; for 3G (WCDMA) use <strong>RSCP</strong>.<br />"
"Typical thresholds: &minus;95 dBm (good), &minus;105 dBm (acceptable), &minus;115 dBm (poor)."
msgstr ""
"Переключиться на резервную SIM, если усреднённый сигнал опустится ниже этого значения.<br />"
"Для LTE и 5G используется <strong>RSRP</strong>, для 3G (WCDMA) — <strong>RSCP</strong>.<br />"
"Типичные пороги: −95 дБм (хорошо), −105 дБм (допустимо), −115 дБм (плохо)."

msgid "Check interval"
msgstr "Интервал проверки"

msgid ""
"How often the daemon polls signal quality and link state.<br />"
"Shorter intervals react faster but increase CPU and modem load.<br />"
"The total evaluation window is <code>Interval × Probes</code>."
msgstr ""
"Как часто демон опрашивает качество сигнала и состояние канала.<br />"
"Меньший интервал ускоряет реакцию, но увеличивает нагрузку на CPU и модем.<br />"
"Суммарное окно оценки: <code>Интервал × Попыток</code>."

msgid "Probes"
msgstr "Попыток"

msgid ""
"Number of signal samples to average before making a switch decision.<br />"
"More probes smooth out momentary fluctuations but slow reaction time.<br />"
"Total evaluation window: <code>Interval × Probes</code>.<br />"
"Example: <code>Interval = 60 sec</code>, <code>Probes = 5</code> → decision after <code>300 sec</code>."
msgstr ""
"Количество замеров сигнала для усреднения перед принятием решения о переключении.<br />"
"Больше попыток сглаживает кратковременные флуктуации, но замедляет реакцию.<br />"
"Суммарное окно оценки: <code>Интервал × Попыток</code>.<br />"
"Например: <code>Интервал = 60 сек</code>, <code>Попыток = 5</code> → решение через <code>300 сек</code>."

msgid "dBm"
msgstr "дБм"

msgid "sec"
msgstr "сек"

msgid "minute"
msgstr "мин"

msgid "hour"
msgstr "ч"

# ── Schedule section ──────────────────────────────────────────────────────────

msgid "Scheduled SIM switch"
msgstr "Переключение по расписанию"

msgid ""
"Unconditional switch to the reserve SIM at a fixed time.<br />"
"Choose how often the switch repeats: every day, every N days, or on a specific weekday.<br />"
"Optionally reverts to the default SIM after a set number of minutes."
msgstr ""
"Безусловное переключение на резервную SIM в заданное время.<br />"
"Выберите, как часто повторяется переключение: каждый день, раз в N дней или в определённый день недели.<br />"
"Опционально возвращается на основную SIM через заданное количество минут."

msgid "Enable scheduled switch"
msgstr "Включить переключение по расписанию"

msgid "Switch time (HH:MM)"
msgstr "Время переключения (ЧЧ:ММ)"

msgid "Time of day to switch to the reserve SIM (24 h format, e.g. <code>02:00</code>)."
msgstr "Время суток для переключения на резервную SIM (24-часовой формат, например <code>02:00</code>)."

msgid "Use HH:MM format"
msgstr "Используйте формат ЧЧ:ММ"

msgid "Invalid time value"
msgstr "Недопустимое значение времени"

msgid "Repeat period"
msgstr "Период повторения"

msgid "Every day"
msgstr "Каждый день"

msgid "Every N days"
msgstr "Раз в N дней"

msgid "Weekly (specific weekday)"
msgstr "Еженедельно (определённый день)"

msgid "Repeat every (days)"
msgstr "Повторять каждые (дней)"

msgid "Switch to your backup SIM card after a specified number of days per month. Minimum 2."
msgstr "Переключаться на резервную SIM через указанное количество дней в месяце. Минимум 2."

msgid "Must be 2 or more"
msgstr "Должно быть 2 или более"

msgid "Weekday"
msgstr "День недели"

msgid "Day of the week on which the switch fires."
msgstr "День недели, в который выполняется переключение."

msgid "Sunday"
msgstr "Воскресенье"

msgid "Monday"
msgstr "Понедельник"

msgid "Tuesday"
msgstr "Вторник"

msgid "Wednesday"
msgstr "Среда"

msgid "Thursday"
msgstr "Четверг"

msgid "Friday"
msgstr "Пятница"

msgid "Saturday"
msgstr "Суббота"

msgid "Revert after (minutes)"
msgstr "Вернуться через (минут)"

msgid ""
"Minutes until automatic revert to the default SIM.<br />"
"Set to <code>0</code> to stay on the reserve SIM indefinitely."
msgstr ""
"Через сколько минут автоматически вернуться на основную SIM.<br />"
"Установите <code>0</code>, чтобы оставаться на резервной SIM до следующего переключения."

msgid "APN for scheduled switch"
msgstr "APN для переключения по расписанию"

msgid ""
"APN to use during the scheduled window.<br />"
"Leave empty to use <em>APN Reserved SIM</em> from Failover settings."
msgstr ""
"APN, используемый в окне переключения по расписанию.<br />"
"Оставьте пустым, чтобы использовать значение «APN — резервная SIM» "
"из настроек переключения по сигналу."
